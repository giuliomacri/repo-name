	keywords = {Space exploration, Ganymede, Jupiter, Europa, Callisto, Jovian system},
	pages = {1-21},
	title = {JUpiter ICy moons Explorer (JUICE): An ESA mission to orbit Ganymede and to characterise the Jupiter system},
