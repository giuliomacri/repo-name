	journal = {Geophysical Research Letters},
	number = {17},
	pages = {2155-2158},
	title = {The magnetic field and magnetosphere of Ganymede},
	url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/97GL02201},
	volume = {24},
	year = {1997},
	bdsk-url-1 = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/97GL02201},
	bdsk-url-2 = {https://doi.org/10.1029/97GL02201}}


